{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": ["scope:mobile", "type:app"],
  "targets": {
    "start": {
      "command": "expo start",
      "options": {
        "cwd": "apps/mobile"
      }
    },
    "build": {
      "command": "expo export",
      "options": {
        "cwd": "apps/mobile"
      }
    },
    "lint": {
      "command": "eslint src/",
      "options": {
        "cwd": "apps/mobile"
      }
    },
    "test": {
      "command": "jest",
      "options": {
        "cwd": "apps/mobile"
      }
    }
  }
}
